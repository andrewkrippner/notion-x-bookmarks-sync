# X (Twitter) OAuth 2.0 credentials — from your app at https://developer.x.com
# The app needs OAuth 2.0 enabled with a callback URI of http://localhost:8080/callback
# and the scopes: tweet.read users.read bookmark.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=

# One-time bootstrap refresh token (obtain with `npm run oauth`).
# After the first sync the worker persists the rotated token in its own state.
X_REFRESH_TOKEN=

# Optional
TIMEZONE=America/Los_Angeles
SYNC_SCHEDULE=1d
